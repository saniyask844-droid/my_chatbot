
<!DOCTYPE html>
<html>
<head>
    <title>Chatbot Task</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #eef2f5; display: flex; justify-content: center; padding: 50px; }
        #chat-container { width: 450px; background: white; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); overflow: hidden; display: flex; flex-direction: column; }
        #history { height: 400px; overflow-y: auto; padding: 20px; border-bottom: 1px solid #eee; }
        .input-area { padding: 20px; display: flex; gap: 10px; background: #fafafa; }
        input { flex: 1; padding: 12px; border: 1px solid #ddd; border-radius: 8px; outline: none; }
        button { padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .user-msg { text-align: right; color: #007bff; margin-bottom: 15px; }
        .bot-msg { text-align: left; background: #f1f1f1; padding: 10px; border-radius: 8px; margin-bottom: 15px; line-height: 1.5; }
    </style>
</head>
<body>
    <div id="chat-container">
        <div id="history"></div>
        <div class="input-area">
            <input type="text" id="userInput" placeholder="Enter User ID (1-10)...">
            <button onclick="send()">Send</button>
        </div>
    </div>

    <script>
        async function send() {
            const input = document.getElementById('userInput');
            const history = document.getElementById('history');
            if(!input.value) return;

            history.innerHTML += `<div class="user-msg"><b>You:</b> ${input.value}</div>`;
            const loadingId = "loading-" + Date.now();
    history.innerHTML += `<div class="bot-msg" id="${loadingId}"><b>Bot:</b> Typing...</div>`;
    history.scrollTop = history.scrollHeight;

    try {
            const response = await fetch('/get_response', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({message: input.value})
            });
            const data = await response.json();
            
            document.getElementById(loadingId).innerHTML = `<b>Bot:</b><br>${data.reply}`;
    } catch (err) {
        document.getElementById(loadingId).innerHTML = `<b>Bot:</b> Connection error!`;
    }
    input.value = '';
    history.scrollTop = history.scrollHeight;
}
    </script>
</body>
</html>